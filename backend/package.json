{
  "name": "agentforge-backend",
  "version": "1.0.0",
  "description": "Backend API for AgentForge - a visual builder for tool-using AI agents",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "mathjs": "^13.1.1",
    "mongodb": "^6.0.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "sql.js": "^1.12.0",
    "vitest": "^4.1.8"
  },
  "vitest": {
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "lcov", "html"],
      "include": ["src/**/*.js"],
      "exclude": ["src/server.js"],
      "thresholds": {
        "lines": 90,
        "functions": 90,
        "branches": 85,
        "statements": 90
      }
    }
  }
}
