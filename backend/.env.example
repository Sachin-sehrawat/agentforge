# Copy this file to .env and fill in your values

# Port the backend server runs on
PORT=4000

# PostgreSQL connection (used when DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentforge
POSTGRES_USER=agentforge
POSTGRES_PASSWORD=agentforge

# Or set a full connection URL (takes precedence over individual vars above)
# DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge

# MongoDB — frontend state storage (user preferences, workspace data, draft agents)
MONGO_URI=mongodb://localhost:27017/agentbuilder
MONGO_PORT=27017
# Connection pool
POSTGRES_POOL_MAX=10
POSTGRES_POOL_MIN=2

# Query behaviour
QUERY_TIMEOUT_MS=5000
SLOW_QUERY_THRESHOLD_MS=1000

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-byte-hex-string

# GitHub OAuth — register an OAuth App at https://github.com/settings/developers
# Authorization callback URL: http://localhost:4000/integrations/github/callback
# Scope requested: repo (or public_repo for public-only access)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AES-256-GCM key for encrypting GitHub access tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_TOKEN_ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# Frontend origin — used to redirect back after the GitHub OAuth callback
FRONTEND_URL=http://localhost:5173
