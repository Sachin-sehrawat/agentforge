# Copy this file to .env and fill in your values

# Server
PORT=4000

# PostgreSQL connection — individual vars (used when DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentforge
POSTGRES_USER=agentforge
POSTGRES_PASSWORD=agentforge

# Or set a full connection URL (takes precedence over individual vars above)
# DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge

# Connection pool
POSTGRES_POOL_MAX=10
POSTGRES_POOL_MIN=2

# Query behaviour
QUERY_TIMEOUT_MS=5000
SLOW_QUERY_THRESHOLD_MS=1000
