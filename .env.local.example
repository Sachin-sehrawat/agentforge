# AgentForge local development environment
# Copy this file to .env.local and adjust values before running docker-compose.
#
# Usage:
#   cp .env.local.example .env.local
#   docker-compose --env-file .env.local up -d

# ============================================================
# Backend
# ============================================================
PORT=4000

# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_PORT=5432
POSTGRES_DB=agentforge
POSTGRES_USER=agentforge
POSTGRES_PASSWORD=agentforge

# Connection pool
POSTGRES_POOL_MAX=10
POSTGRES_POOL_MIN=2

# Full connection URL (takes precedence over individual vars above)
# DATABASE_URL=postgresql://agentforge:agentforge@localhost:5432/agentforge

# ============================================================
# MongoDB
# ============================================================
MONGO_PORT=27017
MONGO_DB=agentforge

# Root credentials used by the MongoDB container (admin user)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=adminpassword

# URI used by the backend when running locally (no Docker):
MONGO_URI=mongodb://localhost:27017/agentforge

# URI used by the backend when running inside Docker Compose (set automatically
# by docker-compose.yml — override here only if you change MONGO_ROOT_USERNAME
# or MONGO_ROOT_PASSWORD):
# MONGO_URI=mongodb://admin:adminpassword@mongodb:27017/agentforge?authSource=admin

# ============================================================
# Query behavior
# ============================================================
QUERY_TIMEOUT_MS=5000
SLOW_QUERY_THRESHOLD_MS=1000
